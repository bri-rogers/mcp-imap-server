{
  "name": "mcp-imap-server",
  "version": "1.0.0",
  "description": "MCP server for IMAP email access",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "INTEGRATION_TEST=true jest --testPathPattern=integration --testTimeout=60000",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "inspector": "./scripts/mcp-inspector.sh",
    "pretest": "npm run typecheck && npm run lint"
  },
  "keywords": [
    "mcp",
    "imap",
    "email",
    "server"
  ],
  "author": "Claude",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "dotenv": "^16.4.5",
    "imap": "^0.8.19",
    "mailparser": "^3.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/imap": "^0.8.40",
    "@types/jest": "^29.5.12",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.11.17",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "semver": "^7.7.2"
  }
}
